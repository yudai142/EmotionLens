# EmotionLens 環境変数テンプレート
# Copy to .env.local for development, .env for production

# Hume.ai API キー（音声・表情解析サービス）
# 取得方法: https://www.hume.ai/docs/api/expression-recognition
HUME_API_KEY=your_hume_api_key_here

# Hume.ai シークレットキー（API 認証）
# HUME_API_KEY と同時に発行される
HUME_SECRET_KEY=your_hume_secret_key_here

# Auth.js のセッション署名に使う秘密鍵
AUTH_SECRET=replace_with_a_long_random_secret

# MVP 用のログイン資格情報
# 開発・検証専用。共有環境や本番では必ず別の値に変更する
AUTH_DEMO_EMAIL=demo@example.com
AUTH_DEMO_PASSWORD=change_me_securely

# PostgreSQL 接続文字列
# 例: postgres://postgres:postgres@localhost:5432/emotion_lens
# users / emotion_sessions / session_alerts テーブルを持つ DB を指定する
DATABASE_URL=postgres://postgres:postgres@localhost:5432/emotion_lens

# Node.js 実行環境
# 値: development または production
NODE_ENV=development

# アプリケーション URL（Vercel など外部ホスティング時に指定）
# 例: https://emotion-lens.vercel.app
# NEXT_PUBLIC_APP_URL=http://localhost:3000
