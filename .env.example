# EmotionLens 環境変数テンプレート
# Copy to .env.local for development, .env for production

# Hume.ai API キー（音声・表情解析サービス）
# 取得方法: https://www.hume.ai/docs/api/expression-recognition
HUME_API_KEY=your_hume_api_key_here

# Hume.ai シークレットキー（API 認証）
# HUME_API_KEY と同時に発行される
HUME_SECRET_KEY=your_hume_secret_key_here

# Node.js 実行環境
# 値: development または production
NODE_ENV=development

# アプリケーション URL（Vercel など外部ホスティング時に指定）
# 例: https://emotion-lens.vercel.app
# NEXT_PUBLIC_APP_URL=http://localhost:3000
